{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "declaration": true,
    "declarationMap": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@oma/environment-local": ["packages/environments/local/src/index.ts"],
      "@oma/harness-claude-code": ["packages/harnesses/claude-code/src/index.ts"],
      "@oma/harness-codex-cli": ["packages/harnesses/codex-cli/src/index.ts"],
      "@oma/harness-opencode": ["packages/harnesses/opencode/src/index.ts"],
      "@oma/harness-pi": ["packages/harnesses/pi/src/index.ts"],
      "@oma/project": ["packages/project/src/index.ts"],
      "@oma/runtime": ["packages/runtime/src/index.ts"],
      "@oma/server": ["packages/server/src/index.ts"],
      "@oma/session-sqlite": ["packages/sessions/sqlite/src/index.ts"],
      "@oma/validators": ["packages/validators/src/index.ts"]
    },
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2023",
    "verbatimModuleSyntax": true
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/test/**/*.ts",
    "packages/*/*/src/**/*.ts",
    "packages/*/*/test/**/*.ts"
  ]
}
